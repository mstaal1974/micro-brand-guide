# ============================================================================
# CLIENT-SIDE (bundled by Vite into the browser JS)
# Put these in .env.local for local dev. NEVER paste real secrets here in a
# deployed environment — anything Vite defines is visible in the JS bundle.
# ============================================================================

# Point this at the same-origin Replicate proxy (recommended for production).
# When set, the browser sends requests to your /api/replicate endpoint and
# the real token stays on the server.
#
#   Production:  REPLICATE_PROXY_URL=/api/replicate
#   Local dev:   leave blank (browser calls Replicate directly — see below)
REPLICATE_PROXY_URL=

# Only needed if REPLICATE_PROXY_URL is blank. Get a token at
# https://replicate.com/account/api-tokens. This value WILL be visible in the
# JS bundle, so only use it during local dev.
REPLICATE_API_TOKEN=

# Supabase project URL + anon key. The anon key is designed to be public —
# permissions are enforced by the RLS policies in db/schema.sql.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Legacy (Gemini) — no longer used. Safe to leave blank.
GEMINI_API_KEY=

# ============================================================================
# SERVER-SIDE (Vercel dashboard env vars — NOT in this file)
# ============================================================================
# When deploying, set REPLICATE_API_TOKEN in Vercel's Environment Variables
# UI (Project Settings → Environment Variables). The serverless function in
# api/replicate/[...path].ts reads it via process.env and injects it into
# Authorization headers. Vite's loadEnv only reads .env files, so this value
# never reaches the client bundle.
