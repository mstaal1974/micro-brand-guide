# Replicate ---------------------------------------------------------------
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Optional same-origin proxy that forwards to https://api.replicate.com
# (required in production because api.replicate.com does not send CORS headers).
# Leave blank for local dev if your browser tolerates the direct call.
REPLICATE_PROXY_URL=

# Supabase ----------------------------------------------------------------
# Project URL + anon key from https://app.supabase.com -> Project Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Legacy (Gemini) — no longer used after the Replicate migration, kept so the
# existing build define statements don't error out at runtime. Safe to leave blank.
GEMINI_API_KEY=
